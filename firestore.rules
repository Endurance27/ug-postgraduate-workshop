rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public site content — anyone can read, only signed-in admin can write
    match /workshop/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // About content — anyone can read, only signed-in admin can write
    match /about/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Image metadata written by ImagesPanel
    match /images/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Speaker records — anyone can read, only signed-in admin can write
    match /speakers/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Registrations:
    //   CREATE — public users can submit the registration form (email must be valid).
    //   UPDATE — public users can update their own record (email field cannot change,
    //            and they cannot manipulate Cloud-Function-only fields like emailSent).
    //   READ / DELETE — admin only.
    //   Cloud Functions (Admin SDK) bypass all rules and can write email metadata.
    match /registrations/{document} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.matches(".*@.*");
      allow update: if request.resource.data.email is string
                    && request.resource.data.email.matches(".*@.*")
                    && request.resource.data.email == resource.data.email
                    && !('emailSent' in request.resource.data)
                    && !('emailDeliveryStatus' in request.resource.data);
      allow read, delete: if request.auth != null;
    }

    // Payments — written by Cloud Function (Admin SDK) or admin only.
    // The frontend no longer writes directly to this collection.
    match /payments/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
