rules_version = '2';
service cloud.firestore {
  function withinAbstractCharLimit(data, field) {
    return !(field in data) || !(data[field] is string) || data[field].size() <= 800;
  }

  function abstractSectionsWithinLimit(data) {
    return withinAbstractCharLimit(data, 'abstractBackground')
        && withinAbstractCharLimit(data, 'abstractMethods')
        && withinAbstractCharLimit(data, 'abstractResults')
        && withinAbstractCharLimit(data, 'abstractSignificance');
  }

  match /databases/{database}/documents {

    // Public site content — anyone can read, only signed-in admin can write
    match /workshop/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // About content — anyone can read, only signed-in admin can write
    match /about/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Image metadata written by ImagesPanel
    match /images/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Speaker records — anyone can read, only signed-in admin can write
    match /speakers/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Registrations:
    //   CREATE — public users can submit the registration form once (email must be
    //            valid). The frontend derives the document ID solely from the
    //            normalized email (see makeDocId(email) in App.tsx), so a second
    //            registration attempt with an already-used email targets the SAME
    //            document. Firestore classifies that as an update, not a create —
    //            and updates require admin auth below — so duplicate-email
    //            registration is rejected server-side no matter what the client does.
    //   READ / UPDATE / DELETE — admin only. There is no legitimate public "edit my
    //            own registration" flow: the form only ever creates a document once,
    //            immediately after a successful Paystack payment.
    //   Cloud Functions (Admin SDK) bypass all rules and can always write regardless
    //            (email delivery metadata, sequential registrationCode, etc.).
    //
    // Abstract sections (Background/Methods/Results/Significance) are capped at 100
    // words each in the UI. Security rules can't count words, so as a backend
    // defense-in-depth check we cap each field at 800 characters — generous enough
    // for 100 real-world words (~6 chars/word average) without false-rejecting.
    match /registrations/{document} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.matches(".*@.*")
                    && abstractSectionsWithinLimit(request.resource.data);
      allow read, update, delete: if request.auth != null;
    }

    // Payments — written by Cloud Function (Admin SDK) or admin only.
    // The frontend no longer writes directly to this collection.
    match /payments/{document} {
      allow read, write: if request.auth != null;
    }

    // Sessions — the single source of truth for seat availability.
    // Anyone can read (the registration form needs live seat counts), but
    // registeredCount/availableSeats can only ever change through the
    // reserveSessionSeat Cloud Function (Admin SDK bypasses this rule), whose
    // transaction is what actually prevents overbooking. Admins can also
    // write directly (e.g. to adjust a session's capacity by hand).
    match /sessions/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
